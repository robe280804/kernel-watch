# ─────────────────────────────────────────────
# KernelWatch — environment configuration
# Copy to .env and adjust for each server
# ─────────────────────────────────────────────

# ── Server identity ───────────────────────────
# Human-readable name for this host (appears in all alerts)
KW_SERVER_NAME=production-hetzner-01

# ── Detection mode ────────────────────────────
# alert   = evaluate rules and dispatch alerts (default)
# monitor = dry-run: evaluate + log alerts, but never call webhook/Slack.
#           Use this for a safe rollout / tuning period on a new host.
KW_MODE=alert

# ── Detection ruleset (YAML, Falco-style) ─────
# Detection rules are DATA, not code: a built-in ruleset is embedded in the
# binary, and you can extend/override/disable rules WITHOUT recompiling. Point
# these at your own YAML and they merge on top of the defaults (override an
# existing rule by id, append: true to extend its tags/exceptions, or add new
# rules). Leave empty to use only the embedded defaults.
#   KW_RULES_FILE = a single overlay file
#   KW_RULES_DIR  = a directory of *.yaml overlays (applied in lexical order)
# Validate a ruleset without root/eBPF (great for CI):  kernelwatch --validate
# A broken file fails fast at startup; a broken hot-reload keeps the last-good
# ruleset (the monitor never disarms). See docs/en/detection-rules.md for the DSL.
KW_RULES_FILE=
KW_RULES_DIR=

# ── Process-lineage detection tuning ──────────
# Detection is context-aware: the same binary (sh, curl, apt) is benign or
# malicious depending on its process ancestry. A shell spawned by cron/the
# scheduler/the entrypoint is suppressed; one spawned by a network-facing
# service (nginx, php-fpm, node…) is escalated as a possible RCE/web-shell.

# How many ancestor processes to resolve per execve (default 5)
KW_ANCESTRY_DEPTH=5

# Extra parent process names to treat as BENIGN supervisors/schedulers, in
# addition to the built-in list (init, systemd, cron, containerd-shim, tini…).
# Comma-separated. Example: your custom job runner.
KW_TRUSTED_PARENTS=

# Extra parent process names to treat as NETWORK-FACING (attack surface), in
# addition to the built-in list (nginx, apache2, php-fpm, node, java…).
KW_NETWORK_PARENTS=

# Tuning escape hatch: suppress any alert whose container name, image, command
# line, or ancestry contains one of these substrings. Comma-separated.
# Example: KW_DETECTION_EXCEPTIONS=ci-runner,backup-image
KW_DETECTION_EXCEPTIONS=

# ── Host (whole-server) monitoring ────────────
# Extend detection from containers to the Docker host itself. OPT-IN: when false
# (default) every host event is dropped at the collector and behavior is
# identical to the container-only build. Recommended rollout: enable with
# KW_MODE=monitor for a 48h per-host tuning window, tune the KW_HOST_* lists
# below, then switch back to KW_MODE=alert.
KW_MONITOR_HOST=false

# Extra host openat path prefixes/substrings to watch, beyond the built-in
# security-relevant set (cron, systemd units, ssh/sudoers/pam, /var/log,
# docker.sock, authorized_keys, cloud credentials…). Comma-separated.
KW_HOST_OPEN_WATCH_EXTRA=

# Comm names to EXCLUDE from host execve monitoring — your fleet agents that
# exec constantly (node_exporter, datadog-agent, telegraf…). Comma-separated.
KW_HOST_EXEC_EXCLUDE=

# Extra processes treated as TRUSTED WRITERS of host persistence/config paths
# (in addition to dpkg/apt/rpm/dnf/snapd/systemd/cloud-init/logrotate/dockerd…).
KW_HOST_TRUSTED_WRITERS=

# Extra parent comms treated as benign supervisors for HOST-scope classification
# only (merged on top of the container trusted-parents list).
KW_HOST_TRUSTED_PARENTS=

# Extra comm names allowed to open /var/run/docker.sock on the host without
# raising host_docker_sock (beyond docker/dockerd/containerd/runc…).
KW_HOST_DOCKER_CLIENTS=

# ── Container filtering ───────────────────────
# Comma-separated list of container names/IDs to monitor (leave empty = monitor ALL)
KW_CONTAINER_WHITELIST=

# Comma-separated list of container names to ignore
KW_CONTAINER_BLACKLIST=kernelwatch,portainer,watchtower

# ── Alert thresholds ──────────────────────────
# Minimum severity to trigger an alert: low | medium | high | critical
KW_ALERT_MIN_SEVERITY=medium

# How many identical alerts per container before suppressing (anti-flood)
KW_ALERT_MAX_RATE=10

# Time window for rate limiting (seconds)
KW_ALERT_RATE_WINDOW=60

# Alert wire format for the log file and webhook bodies:
#   native = enriched KernelWatch JSON (default)
#   ecs    = Elastic Common Schema, for direct ingestion into Elasticsearch /
#            Kibana / Elastic Security and any ECS-aware SIEM.
# Slack always uses the human-readable format regardless of this setting.
KW_ALERT_FORMAT=native

# ── Attack-chain correlation ──────────────────
# Independent findings from the same container's process tree are correlated
# into a single, escalated "attack chain" incident when they span multiple MITRE
# kill-chain stages within the window. This raises true-positive confidence and
# cuts alert fatigue. Correlated incidents bypass severity/rate filtering — they
# are always delivered. Set KW_CORRELATION_ENABLED=false to disable.
KW_CORRELATION_ENABLED=true
# Sliding window over which a container's findings are correlated (seconds)
KW_CORRELATION_WINDOW=300
# Distinct kill-chain stages required to raise an incident
KW_CORRELATION_MIN_STAGES=3
# OR: accumulated risk score required to raise an incident
# (risk points: low=10, medium=25, high=50, critical=100)
KW_CORRELATION_MIN_SCORE=120
# Minimum seconds between incidents for the same container (anti-flap)
KW_CORRELATION_COOLDOWN=300
# Host-bucket overrides: demand a wider chain on the noisier host scope before
# raising an incident. 0 (default) = inherit the values above.
KW_CORRELATION_HOST_MIN_STAGES=0
KW_CORRELATION_HOST_MIN_SCORE=0

# ── SSH brute-force detection (auth-log tailer) ─
# eBPF cannot see authentication outcomes, so SSH credential-stuffing is detected
# by tailing the host auth log. OPT-IN. In Docker, mount the host log read-only
# (compose already mounts /var/log -> /hostlog:ro) and point KW_AUTHLOG_PATH at
# it. Synthesizes host-scope "ssh_bruteforce" alerts (MITRE T1110.001).
KW_AUTHLOG_ENABLED=false
# Debian/Ubuntu: /hostlog/auth.log   RHEL/CentOS: /hostlog/secure
# (bare binary on the host: /var/log/auth.log)
KW_AUTHLOG_PATH=/var/log/auth.log
# Failed attempts from one source IP within the window before alerting
KW_SSH_BRUTE_THRESHOLD=5
KW_SSH_BRUTE_WINDOW=60

# ── Alert destinations ────────────────────────
# Enable file logging (true/false)
KW_LOG_ENABLED=true

# Path for the alert log file (inside the container)
KW_LOG_PATH=/var/log/kernelwatch/alerts.json

# Rotate the alert log past this size (MB) and keep N backups (alerts.json.1…N).
# Prevents the append-only log from filling the host disk. 0 = no rotation.
KW_LOG_MAX_MB=50
KW_LOG_MAX_BACKUPS=3

# Enable webhook alerts (true/false)
KW_WEBHOOK_ENABLED=false
KW_WEBHOOK_URL=https://your-endpoint.example.com/alerts
KW_WEBHOOK_SECRET=changeme

# Enable Slack alerts (true/false)
KW_SLACK_ENABLED=false
KW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
KW_SLACK_CHANNEL=#security-alerts

# ── REST API ──────────────────────────────────
# Authenticated, read/manage API to query the alert & incident history and manage
# false-positive suppressions. Disabled by default (opt-in network surface).
# Requires KW_DB_ENABLED=true for the data endpoints (it queries TimescaleDB).
KW_API_ENABLED=false

# Interface to bind. Defaults to 127.0.0.1 (loopback only). Do NOT set this to
# 0.0.0.0 unless you front the API with TLS + network controls — it is plain HTTP.
KW_API_BIND_ADDR=127.0.0.1

# Port for the REST API
KW_API_PORT=8080

# API bearer token — REQUIRED when KW_API_ENABLED=true. Must be at least 16
# characters and must not contain "changeme". Generate one, e.g.:
#   openssl rand -hex 32
KW_API_TOKEN=

# Endpoints (all under /api/v1 require: Authorization: Bearer <KW_API_TOKEN>):
#   GET    /healthz                      liveness (no auth)
#   GET    /api/v1/alerts?severity=&container=&rule=&since=24h&limit=100
#   GET    /api/v1/stats?since=24h       aggregate counts by severity/rule/container
#   GET    /api/v1/suppressions          list false-positive rules
#   POST   /api/v1/suppressions          add a rule (JSON: rule_id, container_name,
#                                         process_name, substr, reason)
#   DELETE /api/v1/suppressions/{id}     remove a rule
# 'since' accepts a duration (24h, 30m) or an RFC3339 timestamp.

# ── eBPF tuning ───────────────────────────────
# Ring buffer size in bytes (must be a power of two and a multiple of the OS page
# size, default 16MB). Raise on high-syscall-volume hosts to avoid kernel drops
# (watch the `kernel_drops` counter in the periodic stats log).
KW_EBPF_RINGBUF_SIZE=16777216

# ── Health ────────────────────────────────────
# Heartbeat file written by the daemon and checked by `kernelwatch -health`
# (used as the container healthcheck). Lives on the logs volume by default.
KW_HEALTH_FILE=/var/log/kernelwatch/health

# ── Database (TimescaleDB) ────────────────────
# Persist alerts to TimescaleDB for a queryable history. The store is
# best-effort: if the DB is down KernelWatch keeps monitoring (alerts are
# buffered and the log file remains the durable fallback). docker-compose sets
# this to true; the bare binary defaults to false.
KW_DB_ENABLED=false

# Auto-drop alerts older than this many days (TimescaleDB retention). 0 = keep
# forever.
KW_DB_RETENTION_DAYS=90

KW_DB_HOST=localhost
KW_DB_PORT=5432
KW_DB_NAME=kernelwatch
KW_DB_USER=kernelwatch
# REQUIRED when KW_DB_ENABLED=true. Must match the database's password and must
# NOT be left as 'changeme' — the daemon refuses to start otherwise. If you
# change it after the DB volume was first created, reset the volume
# (docker compose down -v) or ALTER the role's password.
KW_DB_PASSWORD=
KW_DB_SSL_MODE=disable
