# ─────────────────────────────────────────────
# KernelWatch — environment configuration
# Copy to .env and adjust for each server
# ─────────────────────────────────────────────

# ── Server identity ───────────────────────────
# Human-readable name for this host (appears in all alerts)
KW_SERVER_NAME=production-hetzner-01

# ── Detection mode ────────────────────────────
# alert   = evaluate rules and dispatch alerts (default)
# monitor = dry-run: evaluate + log alerts, but never call webhook/Slack.
#           Use this for a safe rollout / tuning period on a new host.
KW_MODE=alert

# ── Process-lineage detection tuning ──────────
# Detection is context-aware: the same binary (sh, curl, apt) is benign or
# malicious depending on its process ancestry. A shell spawned by cron/the
# scheduler/the entrypoint is suppressed; one spawned by a network-facing
# service (nginx, php-fpm, node…) is escalated as a possible RCE/web-shell.

# How many ancestor processes to resolve per execve (default 5)
KW_ANCESTRY_DEPTH=5

# Extra parent process names to treat as BENIGN supervisors/schedulers, in
# addition to the built-in list (init, systemd, cron, containerd-shim, tini…).
# Comma-separated. Example: your custom job runner.
KW_TRUSTED_PARENTS=

# Extra parent process names to treat as NETWORK-FACING (attack surface), in
# addition to the built-in list (nginx, apache2, php-fpm, node, java…).
KW_NETWORK_PARENTS=

# Tuning escape hatch: suppress any alert whose container name, image, command
# line, or ancestry contains one of these substrings. Comma-separated.
# Example: KW_DETECTION_EXCEPTIONS=ci-runner,backup-image
KW_DETECTION_EXCEPTIONS=

# ── Container filtering ───────────────────────
# Comma-separated list of container names/IDs to monitor (leave empty = monitor ALL)
KW_CONTAINER_WHITELIST=

# Comma-separated list of container names to ignore
KW_CONTAINER_BLACKLIST=kernelwatch,portainer,watchtower

# ── Alert thresholds ──────────────────────────
# Minimum severity to trigger an alert: low | medium | high | critical
KW_ALERT_MIN_SEVERITY=medium

# How many identical alerts per container before suppressing (anti-flood)
KW_ALERT_MAX_RATE=10

# Time window for rate limiting (seconds)
KW_ALERT_RATE_WINDOW=60

# ── Alert destinations ────────────────────────
# Enable file logging (true/false)
KW_LOG_ENABLED=true

# Path for the alert log file (inside the container)
KW_LOG_PATH=/var/log/kernelwatch/alerts.json

# Rotate the alert log past this size (MB) and keep N backups (alerts.json.1…N).
# Prevents the append-only log from filling the host disk. 0 = no rotation.
KW_LOG_MAX_MB=50
KW_LOG_MAX_BACKUPS=3

# Enable webhook alerts (true/false)
KW_WEBHOOK_ENABLED=false
KW_WEBHOOK_URL=https://your-endpoint.example.com/alerts
KW_WEBHOOK_SECRET=changeme

# Enable Slack alerts (true/false)
KW_SLACK_ENABLED=false
KW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
KW_SLACK_CHANNEL=#security-alerts

# ── API / Dashboard ───────────────────────────
# Port for the REST API and WebSocket server
KW_API_PORT=8080

# API bearer token (leave empty to disable auth — NOT recommended in production)
KW_API_TOKEN=changeme-use-a-strong-random-token

# ── eBPF tuning ───────────────────────────────
# Ring buffer size in bytes (must be a power of two and a multiple of the OS page
# size, default 16MB). Raise on high-syscall-volume hosts to avoid kernel drops
# (watch the `kernel_drops` counter in the periodic stats log).
KW_EBPF_RINGBUF_SIZE=16777216

# ── Health ────────────────────────────────────
# Heartbeat file written by the daemon and checked by `kernelwatch -health`
# (used as the container healthcheck). Lives on the logs volume by default.
KW_HEALTH_FILE=/var/log/kernelwatch/health

# ── Database (TimescaleDB) ────────────────────
# Persist alerts to TimescaleDB for a queryable history. The store is
# best-effort: if the DB is down KernelWatch keeps monitoring (alerts are
# buffered and the log file remains the durable fallback). docker-compose sets
# this to true; the bare binary defaults to false.
KW_DB_ENABLED=false

# Auto-drop alerts older than this many days (TimescaleDB retention). 0 = keep
# forever.
KW_DB_RETENTION_DAYS=90

KW_DB_HOST=localhost
KW_DB_PORT=5432
KW_DB_NAME=kernelwatch
KW_DB_USER=kernelwatch
KW_DB_PASSWORD=changeme
KW_DB_SSL_MODE=disable
