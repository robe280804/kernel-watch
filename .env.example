# ─────────────────────────────────────────────
# ContainerSentry — environment configuration
# Copy to .env and adjust for each server
# ─────────────────────────────────────────────

# ── Server identity ───────────────────────────
# Human-readable name for this host (appears in all alerts)
CS_SERVER_NAME=production-hetzner-01

# ── Container filtering ───────────────────────
# Comma-separated list of container names/IDs to monitor (leave empty = monitor ALL)
CS_CONTAINER_WHITELIST=

# Comma-separated list of container names to ignore
CS_CONTAINER_BLACKLIST=containersentry,portainer,watchtower

# ── Alert thresholds ──────────────────────────
# Minimum severity to trigger an alert: low | medium | high | critical
CS_ALERT_MIN_SEVERITY=medium

# How many identical alerts per container before suppressing (anti-flood)
CS_ALERT_MAX_RATE=10

# Time window for rate limiting (seconds)
CS_ALERT_RATE_WINDOW=60

# ── Alert destinations ────────────────────────
# Enable file logging (true/false)
CS_LOG_ENABLED=true

# Path for the alert log file (inside the container)
CS_LOG_PATH=/var/log/containersentry/alerts.json

# Enable webhook alerts (true/false)
CS_WEBHOOK_ENABLED=false
CS_WEBHOOK_URL=https://your-endpoint.example.com/alerts
CS_WEBHOOK_SECRET=changeme

# Enable Slack alerts (true/false)
CS_SLACK_ENABLED=false
CS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
CS_SLACK_CHANNEL=#security-alerts

# ── API / Dashboard ───────────────────────────
# Port for the REST API and WebSocket server
CS_API_PORT=8080

# API bearer token (leave empty to disable auth — NOT recommended in production)
CS_API_TOKEN=changeme-use-a-strong-random-token

# ── eBPF tuning ───────────────────────────────
# Ring buffer size in bytes (must be multiple of os page size, default 16MB)
CS_EBPF_RINGBUF_SIZE=16777216

# ── Database (TimescaleDB) ────────────────────
CS_DB_HOST=localhost
CS_DB_PORT=5432
CS_DB_NAME=containersentry
CS_DB_USER=containersentry
CS_DB_PASSWORD=changeme
CS_DB_SSL_MODE=disable
